{
  "openapi": "3.1.0",
  "info": {
    "title": "utoipa-axum",
    "description": "Utoipa's axum bindings for seamless integration for the two",
    "contact": {
      "name": "Juha Kukkonen",
      "email": "juha7kukkonen@gmail.com"
    },
    "license": {
      "name": "MIT OR Apache-2.0",
      "identifier": "MIT OR Apache-2.0"
    },
    "version": "0.2.0"
  },
  "paths": {
    "/movie/{id}": {
      "get": {
        "operationId": "movie_details",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaItem"
                }
              }
            }
          }
        }
      }
    },
    "/search": {
      "get": {
        "operationId": "search",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SearchResult"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/streams/movie/{id}": {
      "get": {
        "operationId": "movie_streams",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Stream"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/streams/start/{info_hash}/{file_idx}": {
      "post": {
        "operationId": "start_stream",
        "parameters": [
          {
            "name": "info_hash",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "file_idx",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StartStreamResponse"
                }
              }
            }
          }
        }
      }
    },
    "/streams/tv/{id}/{season}/{episode}": {
      "get": {
        "operationId": "tv_streams",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "season",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "episode",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Stream"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tv/{id}": {
      "get": {
        "operationId": "tv_details",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaItem"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Genre": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "Image": {
        "type": "object",
        "required": [
          "file_path",
          "width",
          "height",
          "vote_average"
        ],
        "properties": {
          "file_path": {
            "type": "string"
          },
          "height": {
            "type": "integer",
            "format": "int64"
          },
          "iso_639_1": {
            "type": [
              "string",
              "null"
            ]
          },
          "vote_average": {
            "type": "number",
            "format": "double"
          },
          "width": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "Images": {
        "type": "object",
        "required": [
          "posters",
          "backdrops",
          "logos"
        ],
        "properties": {
          "backdrops": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Image"
            }
          },
          "logos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Image"
            }
          },
          "posters": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Image"
            }
          }
        }
      },
      "MediaItem": {
        "type": "object",
        "required": [
          "id",
          "media_type",
          "title",
          "genres",
          "videos"
        ],
        "properties": {
          "backdrop_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "genres": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Genre"
            }
          },
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "images": {
            "oneOf": [
              {
                "type": "null"
              },
              {
                "$ref": "#/components/schemas/Images"
              }
            ]
          },
          "imdb_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "media_type": {
            "$ref": "#/components/schemas/MediaType"
          },
          "overview": {
            "type": [
              "string",
              "null"
            ]
          },
          "poster_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "rating": {
            "type": [
              "number",
              "null"
            ],
            "format": "double"
          },
          "release_date": {
            "type": [
              "string",
              "null"
            ]
          },
          "runtime": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "seasons": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "$ref": "#/components/schemas/Season"
            }
          },
          "tagline": {
            "type": [
              "string",
              "null"
            ]
          },
          "title": {
            "type": "string"
          },
          "videos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Video"
            }
          }
        }
      },
      "MediaType": {
        "type": "string",
        "enum": [
          "movie",
          "tv"
        ]
      },
      "SearchResult": {
        "type": "object",
        "required": [
          "id",
          "media_type",
          "title"
        ],
        "properties": {
          "backdrop_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "media_type": {
            "$ref": "#/components/schemas/MediaType"
          },
          "overview": {
            "type": [
              "string",
              "null"
            ]
          },
          "poster_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "release_date": {
            "type": [
              "string",
              "null"
            ]
          },
          "title": {
            "type": "string"
          }
        }
      },
      "Season": {
        "type": "object",
        "required": [
          "id",
          "season_number",
          "name",
          "episode_count"
        ],
        "properties": {
          "air_date": {
            "type": [
              "string",
              "null"
            ]
          },
          "episode_count": {
            "type": "integer",
            "format": "int64"
          },
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          },
          "poster_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "season_number": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "StartStreamResponse": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string"
          }
        }
      },
      "Stream": {
        "type": "object",
        "required": [
          "info_hash",
          "file_idx",
          "name",
          "title",
          "source",
          "hdr",
          "score"
        ],
        "properties": {
          "audio": {
            "type": [
              "string",
              "null"
            ]
          },
          "codec": {
            "type": [
              "string",
              "null"
            ]
          },
          "file_idx": {
            "type": "integer",
            "format": "int64"
          },
          "hdr": {
            "type": "boolean"
          },
          "info_hash": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "resolution": {
            "type": [
              "string",
              "null"
            ]
          },
          "score": {
            "type": "number",
            "format": "double"
          },
          "seeders": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32",
            "minimum": 0
          },
          "size_bytes": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "minimum": 0
          },
          "size_display": {
            "type": [
              "string",
              "null"
            ]
          },
          "source": {
            "type": "string"
          },
          "source_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "title": {
            "type": "string"
          }
        }
      },
      "Video": {
        "type": "object",
        "required": [
          "key",
          "site",
          "name",
          "video_type"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "site": {
            "type": "string"
          },
          "video_type": {
            "type": "string"
          }
        }
      }
    }
  }
}