  "components": {
    "schemas": {
      "CollectionItem": {
        "type": "object",
        "required": [
          "collection",
          "media_type",
          "tmdb_id",
          "title",
          "added_at"
        ],
        "properties": {
          "added_at": {
            "type": "string"
          },
          "collection": {
            "type": "string"
          },
          "media_type": {
            "type": "string"
          },
          "poster_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "title": {
            "type": "string"
          },
          "tmdb_id": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "CollectionRequest": {
        "type": "object",
        "required": [
          "collection",
          "media_type",
          "tmdb_id",
          "title"
        ],
        "properties": {
          "collection": {
            "type": "string"
          },
          "media_type": {
            "type": "string"
          },
          "poster_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "title": {
            "type": "string"
          },
          "tmdb_id": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "CollectionStatus": {
        "type": "object",
        "required": [
          "in_collection"
        ],
        "properties": {
          "in_collection": {
            "type": "boolean"
          }
        }
      },
      "Episode": {
        "type": "object",
        "required": [
          "episode_number",
          "name"
        ],
        "properties": {
          "episode_number": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          },
          "overview": {
            "type": [
              "string",
              "null"
            ]
          },
          "still_path": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      },
      "Genre": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          }
        }
      },
      "MediaItem": {
        "type": "object",
        "required": [
          "id",
          "media_type",
          "title",
          "backdrops",
          "genres",
          "videos"
        ],
        "properties": {
          "backdrops": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "genres": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Genre"
            }
          },
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "imdb_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "logo_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "media_type": {
            "$ref": "#/components/schemas/MediaType"
          },
          "overview": {
            "type": [
              "string",
              "null"
            ]
          },
          "poster_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "rating": {
            "type": [
              "number",
              "null"
            ],
            "format": "double"
          },
          "release_date": {
            "type": [
              "string",
              "null"
            ]
          },
          "runtime": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "seasons": {
            "type": [
              "array",
              "null"
            ],
            "items": {
              "$ref": "#/components/schemas/Season"
            }
          },
          "tagline": {
            "type": [
              "string",
              "null"
            ]
          },
          "title": {
            "type": "string"
          },
          "videos": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Video"
            }
          }
        }
      },
      "MediaType": {
        "type": "string",
        "enum": [
          "movie",
          "tv"
        ]
      },
      "RecordWatchRequest": {
        "type": "object",
        "required": [
          "media_type",
          "tmdb_id",
          "title"
        ],
        "properties": {
          "duration": {
            "type": [
              "number",
              "null"
            ],
            "format": "double"
          },
          "episode": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "file_idx": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "info_hash": {
            "type": [
              "string",
              "null"
            ]
          },
          "media_type": {
            "type": "string"
          },
          "poster_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "progress": {
            "type": [
              "number",
              "null"
            ],
            "format": "double"
          },
          "season": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64"
          },
          "title": {
            "type": "string"
          },
          "tmdb_id": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "SearchResult": {
        "type": "object",
        "required": [
          "id",
          "media_type",
          "title"
        ],
        "properties": {
          "backdrop_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "media_type": {
            "$ref": "#/components/schemas/MediaType"
          },
          "overview": {
            "type": [
              "string",
              "null"
            ]
          },
          "poster_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "release_date": {
            "type": [
              "string",
              "null"
            ]
          },
          "title": {
            "type": "string"
          }
        }
      },
      "Season": {
        "type": "object",
        "required": [
          "id",
          "season_number",
          "name",
          "episode_count",
          "episodes"
        ],
        "properties": {
          "air_date": {
            "type": [
              "string",
              "null"
            ]
          },
          "episode_count": {
            "type": "integer",
            "format": "int64"
          },
          "episodes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Episode"
            }
          },
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          },
          "poster_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "season_number": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "StartStreamResponse": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string"
          }
        }
      },
      "Stream": {
        "type": "object",
        "required": [
          "info_hash",
          "file_idx",
          "name",
          "title",
          "source",
          "hdr",
          "imax",
          "score"
        ],
        "properties": {
          "audio": {
            "type": [
              "string",
              "null"
            ]
          },
          "codec": {
            "type": [
              "string",
              "null"
            ]
          },
          "file_idx": {
            "type": "integer",
            "format": "int64"
          },
          "hdr": {
            "type": "boolean"
          },
          "imax": {
            "type": "boolean"
          },
          "info_hash": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "resolution": {
            "type": [
              "string",
              "null"
            ]
          },
          "score": {
            "type": "number",
            "format": "double"
          },
          "seeders": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int32",
            "minimum": 0
          },
          "size_bytes": {
            "type": [
              "integer",
              "null"
            ],
            "format": "int64",
            "minimum": 0
          },
          "size_display": {
            "type": [
              "string",
              "null"
            ]
          },
          "source": {
            "type": "string"
          },
          "source_type": {
            "type": [
              "string",
              "null"
            ]
          },
          "title": {
            "type": "string"
          }
        }
      },
      "SubtitleCue": {
        "type": "object",
        "required": [
          "start",
          "end",
          "text"
        ],
        "properties": {
          "end": {
            "type": "number",
            "format": "double",
            "description": "End time in seconds"
          },
          "start": {
            "type": "number",
            "format": "double",
            "description": "Start time in seconds"
          },
          "text": {
            "type": "string"
          }
        }
      },
      "SubtitleTrack": {
        "type": "object",
        "required": [
          "id",
          "language",
          "url",
          "score"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "score": {
            "type": "integer",
            "format": "int64",
            "description": "Higher score = more likely to be in sync"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "Video": {
        "type": "object",
        "required": [
          "key",
          "site",
          "name",
          "video_type"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "site": {
            "type": "string"
          },
          "video_type": {
            "type": "string"
          }
        }
      },
      "WatchHistoryItem": {
        "type": "object",
        "required": [
          "media_type",
          "tmdb_id",
          "title",
          "season",
          "episode",
          "file_idx",
          "progress",
          "duration",
          "last_watched"
        ],
        "properties": {
          "duration": {
            "type": "number",
            "format": "double"
          },
          "episode": {
            "type": "integer",
            "format": "int64"
          },
          "file_idx": {
            "type": "integer",
            "format": "int64"
          },
          "info_hash": {
            "type": [
              "string",
              "null"
            ]
          },
          "last_watched": {
            "type": "string"
          },
          "media_type": {
            "type": "string"
          },
          "poster_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "progress": {
            "type": "number",
            "format": "double"
          },
          "season": {
            "type": "integer",
            "format": "int64"
          },
          "title": {
            "type": "string"
          },
          "tmdb_id": {
            "type": "integer",
            "format": "int64"
          }
        }
      }
    }
  }
}