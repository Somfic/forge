{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClientMsg",
  "oneOf": [
    {
      "description": "Host only — set the content for the room",
      "type": "object",
      "required": [
        "file_idx",
        "info_hash",
        "media_type",
        "title",
        "tmdb_id",
        "type"
      ],
      "properties": {
        "episode": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "file_idx": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "info_hash": {
          "type": "string"
        },
        "media_type": {
          "type": "string"
        },
        "poster_path": {
          "type": [
            "string",
            "null"
          ]
        },
        "season": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0.0
        },
        "title": {
          "type": "string"
        },
        "tmdb_id": {
          "type": "integer",
          "format": "int64"
        },
        "type": {
          "type": "string",
          "enum": [
            "set_content"
          ]
        }
      }
    },
    {
      "description": "Host only — sync navigation to guests",
      "type": "object",
      "required": [
        "type",
        "url"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "navigate"
          ]
        },
        "url": {
          "type": "string"
        }
      }
    },
    {
      "description": "Stream has loaded and is ready to play",
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "loaded"
          ]
        }
      }
    },
    {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "ready"
          ]
        }
      }
    },
    {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "unready"
          ]
        }
      }
    },
    {
      "type": "object",
      "required": [
        "position",
        "type"
      ],
      "properties": {
        "position": {
          "type": "number",
          "format": "double"
        },
        "type": {
          "type": "string",
          "enum": [
            "play"
          ]
        }
      }
    },
    {
      "type": "object",
      "required": [
        "position",
        "type"
      ],
      "properties": {
        "position": {
          "type": "number",
          "format": "double"
        },
        "type": {
          "type": "string",
          "enum": [
            "pause"
          ]
        }
      }
    },
    {
      "type": "object",
      "required": [
        "position",
        "type"
      ],
      "properties": {
        "position": {
          "type": "number",
          "format": "double"
        },
        "type": {
          "type": "string",
          "enum": [
            "seek"
          ]
        }
      }
    },
    {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "ping"
          ]
        }
      }
    }
  ]
}